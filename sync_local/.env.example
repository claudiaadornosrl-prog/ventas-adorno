# ═══════════════════════════════════════════════════════════
#  sync_ventas_local — variables de entorno
#  Copiar este archivo como .env y completar los valores
# ═══════════════════════════════════════════════════════════

# Qué local soy
# Opciones: alcorta | unicenter | oficina
VENTAS_LOCAL=unicenter

# SQL Server local del Dragonfish (Server, no Terminal)
# Default: localhost\ZOOLOGIC2026
# Cambiar si la instancia tiene otro nombre
VENTAS_SQL_SERVER=localhost\ZOOLOGIC2026

# Supabase (estos NO se commitean al repo)
SUPABASE_URL=https://kwwiykssrpabncpqtmwi.supabase.co
SUPABASE_SERVICE_KEY=

# Frecuencia del polling (segundos). 60 = chequea cada minuto
POLL_SECONDS=60

# Archivo de log (default: junto al script)
# LOG_FILE=C:\CRM_Adorno\ventas-adorno\sync_local\sync.log
